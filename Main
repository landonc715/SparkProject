run = True

while run == True:
    print("Welcome to the study quizzes!")
    print("Please select a subject from the following options:")
    print("Math = 1", "Chemistry = 2", "Biology = 3", "History = 4", "Coding = 5", sep="\n")
    input = int(input("Enter the number corresponding to your subject choice: "))
    if input == 1:
        print("Starting Stage 1/3 of the Math quiz!")
        score = 0
       





    elif input == 2:
        print("Starting Stage 1/3 of the Chemistry quiz!")
        score = 0

        while score == 0:

            print("What element is Fe?")
            print ("1. Iron", "2. Fluorine", "3. Francium", "4. Fermium", sep="\n")
            answer = input()
            if answer == "1":
                print("Correct! Moving on to the next question!")
                score += 1
        while score == 1:

            print("Which subatomic particle has a negative charge?")
            print ("1. Proton", "2. Electron", "3. Neutron", "4. cell", sep="\n")
            answer = input()
            if answer == "2":
                print("Correct! Moving on to the next question!")
                score += 1
        while score == 2:

            print("What does the atomic number of an element tell you about an atom?", sep="\n")
            print ("1. # of electrons", "2. # of neutrons", "3. # of protons", "4. Atomic mass", sep="\n")
            answer = input()
            if answer == "3":
                print("Correct! All done with this level! Moving on to the next stage!")
                print("You are 1/3 of the way through the Chemistry quiz")
                score += 1

        





    elif input == 3:
        print("Starting Stage 1/3 of the Biology quiz!")
    elif input == 4:
        print("Starting Stage 1/3 of the History quiz!")
    elif input == 5:
        print("Starting Stage 1/3 of the Coding quiz!")
    
